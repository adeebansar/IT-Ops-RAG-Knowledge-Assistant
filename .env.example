# Optional.
# The app works in retrieval-only mode without these.
# Add one of these if you want generated AI answers.

OPENAI_API_KEY=your_openai_key_here

# OR

OPENROUTER_API_KEY=your_openrouter_key_here

# Optional.
# Leave this off for the beginner demo.
# Set to true only if you want to download and use the Hugging Face sentence-transformers model.

USE_HUGGINGFACE_EMBEDDINGS=false
